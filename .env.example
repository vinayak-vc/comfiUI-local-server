APP_NAME=ComfyUI Orchestration Platform
APP_VERSION=0.1.0
ENVIRONMENT=local
DEBUG=false
API_PREFIX=/api
CORS_ALLOWED_ORIGINS=[]
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
DATABASE_ECHO=false
REDIS_URL=redis://redis:6379/0
REDIS_SOCKET_TIMEOUT_SECONDS=5
LOG_LEVEL=INFO
LOG_JSON=true
LOG_FILE_PATH=logs/app.log
UPLOADS_PATH=uploads
OUTPUTS_PATH=outputs
WORKFLOWS_PATH=workflows
MAX_UPLOAD_SIZE_BYTES=104857600
ALLOWED_UPLOAD_EXTENSIONS=[".png",".jpg",".jpeg",".webp",".gif",".mp4",".webm",".mov"]
UPLOAD_URL_PREFIX=/uploads
STORAGE_CLEANUP_AFTER_DAYS=30
DATABASE_AUTO_CREATE_TABLES=true
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOW_USER_REGISTRATION=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120
API_KEY_HEADER_NAME=X-API-Key
COMFYUI_BASE_URL=http://comfyui:8188
COMFYUI_WS_URL=ws://comfyui:8188/ws
COMFYUI_REQUEST_TIMEOUT_SECONDS=30
COMFYUI_EXECUTION_TIMEOUT_SECONDS=1800
COMFYUI_POLL_INTERVAL_SECONDS=1
COMFYUI_JOB_TTL_SECONDS=86400
OUTPUT_URL_PREFIX=/outputs
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND_URL=redis://redis:6379/0
CELERY_QUEUE_NAME=gpu_render_queue
CELERY_WORKER_CONCURRENCY=1
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=1800
CELERY_TASK_TIME_LIMIT_SECONDS=1860
CELERY_TASK_MAX_RETRIES=2
CELERY_TASK_RETRY_DELAY_SECONDS=30
SOCKETIO_PATH=socket.io
SOCKETIO_CHANNEL=socketio
SOCKETIO_ALLOWED_ORIGINS=[]
SOCKETIO_PREVIEW_ENCODING=base64
